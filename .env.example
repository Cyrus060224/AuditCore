# ═══════════════════════════════════════════════════════
# AuditCore 模型配置
# ═══════════════════════════════════════════════════════

# ── 全局默认配置 ──
# LLM_PROVIDER 可选值: openai / deepseek / moonshot / qwen / siliconflow / ollama / anthropic
LLM_PROVIDER=ollama
LLM_API_KEY=ollama
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=llama3:8b

# ── 审计流水线参数 ──
AUDIT_LANG=中文
CONSISTENCY_THRESHOLD=0.80

# ═══════════════════════════════════════════════════════
# 按 Agent 覆盖（可选，不填则使用全局默认）
# ═══════════════════════════════════════════════════════
# 取消注释即可为单个 Agent 指定独立模型：
#
# JUNIOR_LLM_PROVIDER=openai
# JUNIOR_LLM_API_KEY=sk-xxx
# JUNIOR_LLM_MODEL=gpt-4o-mini
#
# CHALLENGER_LLM_PROVIDER=openai
# CHALLENGER_LLM_API_KEY=sk-xxx
# CHALLENGER_LLM_MODEL=gpt-4o
#
# FACTCHECK_LLM_PROVIDER=deepseek
# FACTCHECK_LLM_API_KEY=sk-xxx
# FACTCHECK_LLM_MODEL=deepseek-chat
#
# SENIOR_LLM_PROVIDER=anthropic
# SENIOR_LLM_API_KEY=sk-ant-xxx
# SENIOR_LLM_MODEL=claude-sonnet-4-20250514

# ═══════════════════════════════════════════════════════
# 提供商配置示例
# ═══════════════════════════════════════════════════════

# --- OpenAI ---
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-xxxxxxxxxxxx
# LLM_MODEL=gpt-4o-mini

# --- DeepSeek ---
# LLM_PROVIDER=deepseek
# LLM_API_KEY=sk-xxxxxxxxxxxx
# LLM_MODEL=deepseek-chat

# --- 通义千问（阿里云 DashScope） ---
# LLM_PROVIDER=qwen
# LLM_API_KEY=sk-xxxxxxxxxxxx
# LLM_MODEL=qwen-plus

# --- Moonshot（月之暗面） ---
# LLM_PROVIDER=moonshot
# LLM_API_KEY=sk-xxxxxxxxxxxx
# LLM_MODEL=moonshot-v1-8k

# --- 硅基流动 SiliconFlow ---
# LLM_PROVIDER=siliconflow
# LLM_API_KEY=sk-xxxxxxxxxxxx
# LLM_MODEL=deepseek-ai/DeepSeek-V3

# --- Anthropic Claude ---
# LLM_PROVIDER=anthropic
# LLM_API_KEY=sk-ant-xxxxxxxxxxxx
# LLM_MODEL=claude-sonnet-4-20250514

# --- 本地 Ollama ---
# LLM_PROVIDER=ollama
# LLM_API_KEY=ollama
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=llama3:8b

# ═══════════════════════════════════════════════════════
# 向后兼容旧变量名（当 LLM_* 未设置时生效）
# ═══════════════════════════════════════════════════════
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
